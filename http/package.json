{
  "name": "@khoralabs/chat-http",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./routes": {
      "types": "./src/routes.ts",
