      "default": "./src/routes.ts"
    },
    "./service": {
      "types": "./src/service.ts",
      "import": "./src/service.ts",
      "default": "./src/service.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    }
