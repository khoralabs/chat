{
  "name": "chat",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "biome": "biome check .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "typecheck": "bun run --filter '@khoralabs/chat' typecheck && bun run --filter '@khoralabs/chat-react' typecheck",
    "test": "bun test",
    "prepare": "husky",
    "build": "bun run scripts/build-packages.ts",
    "release:bump": "bun run scripts/bump-versions.ts",
    "release:publish": "bun run scripts/publish-packages.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
