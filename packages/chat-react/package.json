{
  "name": "@khoralabs/chat-react",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "module": "src/index.tsx",
  "imports": {
    "#components/*": "./src/components/*",
    "#lib/*": "./src/lib/*",
    "#hooks/*": "./src/hooks/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./ui": {
      "types": "./src/ui/index.tsx",
      "import": "./src/ui/index.tsx",
      "default": "./src/ui/index.tsx"
    },
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun run ../../scripts/build-package.ts ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^7.0.9",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "radix-ui": "^1.6.0",
    "shadcn": "^3.0.0",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.1.11",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "@khoralabs/chat": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "typescript": "^5"
  },
  "description": "React hooks and UI for @khoralabs/chat",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khoralabs/chat.git",
    "directory": "packages/chat-react"
  },
  "homepage": "https://github.com/khoralabs/chat/tree/main/packages/chat-react#readme",
  "bugs": "https://github.com/khoralabs/chat/issues"
}
